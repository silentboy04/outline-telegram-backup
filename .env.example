# Outline instance URL (self-hosted or cloud)
OUTLINE_URL=https://your-outline-instance.com

# Outline API key (Settings → API)
OUTLINE_API_KEY=ol_api_YOUR_TOKEN_HERE

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram chat/group ID
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Telegram topic/thread ID (optional, for supergroup topics)
TELEGRAM_THREAD_ID=

# Max backup archives to keep (default: 4)
KEEP_BACKUPS=4
